# Copy this file to .env for local dev. On Railway, set these as actual
# environment variables in the service settings — this file isn't used there.

ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
# Comma-separated. Include your Vercel production domain AND preview pattern.
ALLOWED_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/startusbusiness

JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Server-side only — never expose this key to the frontend.
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6

# Supabase Storage. Leave both empty for local-disk fallback (dev only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=startusbusiness-documents
STORAGE_ROOT=/data/documents

RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=StartUSBusiness <notifications@yourdomain.com>
